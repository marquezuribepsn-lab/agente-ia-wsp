# Proveedor de LLM: cualquier API compatible con el formato de OpenAI sirve.
# LLM_BASE_URL es opcional (default: OpenRouter). Ejemplos:
#   OpenRouter:      https://openrouter.ai/api/v1        (LLM_MODEL=openai/gpt-4o-mini)
#   Groq:            https://api.groq.com/openai/v1      (LLM_MODEL=llama-3.3-70b-versatile)
#   Google Gemini:   https://generativelanguage.googleapis.com/v1beta/openai/  (LLM_MODEL=gemini-2.0-flash)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Opcional: si se completan ambas, el dashboard exige HTTP Basic Auth en
# todas las rutas. Fuertemente recomendado si vas a exponerlo a internet
# sin un dominio propio (sin proxy con auth delante).
DASHBOARD_USER=
DASHBOARD_PASSWORD=
